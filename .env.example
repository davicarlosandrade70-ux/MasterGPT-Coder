# -----------------------------------------------------------------------------
# MASTERGPT-CODER - CONFIGURAÇÃO DE AMBIENTE (EXEMPLO)
# -----------------------------------------------------------------------------

# 1. BANCO DE DADOS (SUPABASE / POSTGRESQL)
# Formato: postgresql+asyncpg://[user]:[password]@[host]:[port]/[dbname]
# No Supabase, vá em Settings -> Database -> Connection string -> Python (SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://postgres:SUA_SENHA_AQUI@db.SEU_ID.supabase.co:5432/postgres

# 2. SEGURANÇA (JWT)
# Gere uma chave aleatória forte: openssl rand -hex 32
SECRET_KEY=sua_chave_secreta_super_segura_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200 # 30 dias

# 3. LLM API KEYS (OPCIONAL NO LOCAL, OBRIGATÓRIO NA VERCEL)
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
MISTRAL_API_KEY=...

# 4. CONFIGURAÇÃO VERCEL
# Na Vercel, adicione estas variáveis em Settings -> Environment Variables
